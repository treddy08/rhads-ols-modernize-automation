---
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ ocp4_workload_tenant_mta_user }}-mta
  namespace: openshift-gitops
  finalizers:
  - resources-finalizer.argocd.argoproj.io
spec:
  destination:
    name: ''
    namespace: {{ ocp4_workload_tenant_mta_namespace }}
    server: 'https://kubernetes.default.svc'
  project: "{{ ocp4_workload_tenant_mta_user_app_project_prefix }}-{{ ocp4_workload_tenant_mta_user }}"
  syncPolicy:
    syncOptions:
    - CreateNamespace=true
    automated:
      prune: false
      selfHeal: false
  source:
    repoURL: {{ ocp4_workload_tenant_mta_repo }}
    targetRevision: {{ ocp4_workload_tenant_mta_repo_tag }}
    path: {{ ocp4_workload_tenant_mta_repo_path }}
    helm:
      values: |
        fullNameOverride: {{ ocp4_workload_tenant_mta_namespace }}
        namespacePermissions:
          user: {{ ocp4_workload_tenant_mta_user }}
          role: {{ ocp4_workload_tenant_mta_role }}
        seedTackle: {{ ocp4_workload_tenant_mta_seed }}
        deployOperator: false
{% if ocp4_workload_tenant_mta_seed | bool %}
        seedJob:
          repository: {{ ocp4_workload_tenant_mta_seed_image }}
          tag: "{{ ocp4_workload_tenant_mta_seed_tag }}"
          pullPolicy: {{ ocp4_workload_tenant_mta_seed_pull_policy }}
{% endif %}
        tackleInstance:
          rwxSupported: "{{ ocp4_workload_tenant_mta_rwx_supported | bool }}"
{% if ocp4_workload_tenant_mta_feature_auth_required is defined %}
          featureAuthRequired: {{ ocp4_workload_tenant_mta_feature_auth_required }}
{% endif %}
{% if ocp4_workload_tenant_mta_rwx_storage_class | default("") | length > 0 %}
          rwxStorageClass: {{ ocp4_workload_tenant_mta_rwx_storage_class }}
{% endif %}
{% if ocp4_workload_tenant_mta_rwo_storage_class | default("") | length > 0 %}
          rwoStorageClass: {{ ocp4_workload_tenant_mta_rwo_storage_class }}
{% endif %}
{% if ocp4_workload_tenant_mta_maven_data_volume_size | default("") | length > 0 %}
          mavenDataVolumeSize: {{ ocp4_workload_tenant_mta_maven_data_volume_size }}
{% endif %}
{% if ocp4_workload_tenant_mta_hub_database_volume_size | default("") | length > 0 %}
          hubDatabaseVolumeSize: {{ ocp4_workload_tenant_mta_hub_database_volume_size }}
{% endif %}
{% if ocp4_workload_tenant_mta_keycloak_database_data_volume_size | default("") | length > 0 %}
          keycloakDatabaseDataVolumeSize: {{ ocp4_workload_tenant_mta_keycloak_database_data_volume_size }}
{% endif %}
{% if ocp4_workload_tenant_mta_pathfinder_database_data_volume_size | default("") | length > 0 %}
          pathfinderDatabaseDataVolumeSize: {{ ocp4_workload_tenant_mta_pathfinder_database_data_volume_size }}
{% endif %}
